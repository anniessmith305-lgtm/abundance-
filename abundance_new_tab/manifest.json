{
    "manifest_version": 3,
    "name": "Abundance Luxury New Tab",
    "version": "1.0",
    "description": "A minimal, luxury deep emerald and gold new tab experience for focus and abundance.",
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://graph.facebook.com/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}